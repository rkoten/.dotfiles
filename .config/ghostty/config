background-blur = 8
background-opacity = 0.92
background-opacity-cells = true
click-repeat-interval = 400
cursor-style = block
custom-shader = "~/.dotfiles/.config/ghostty/cubes.glsl"
custom-shader-animation = always
font-family = "JetBrainsMono Nerd Font"
font-feature = "-calt"
font-size = 15
macos-icon = custom-style
macos-icon-frame = plastic
macos-icon-ghost-color = #00BBFF
macos-icon-screen-color = black
macos-titlebar-proxy-icon = hidden
mouse-scroll-multiplier = precision:2.6,discrete:3
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 60s
scrollback-limit = 31337000
shell-integration-features = no-cursor
split-inherit-working-directory = true
tab-inherit-working-directory = true
theme = "Monokai Remastered"
window-inherit-working-directory = false
window-save-state = always
